
GOMA_DB_HOST="localhost"
GOMA_DB_USER=goma
GOMA_DB_PASSWORD=goma
GOMA_DB_NAME=goma
GOMA_DB_PORT=5432
GOMA_DB_SSL_MODE=disable

GOMA_ENABLE_DOCS=true
GOMA_ENVIRONMENT=development
GOMA_CORS_ALLOWED_ORIGINS=
GOMA_JWT_SECRET=
GOMA_JWT_ISSUER=goma-admin
GOMA_LOG_LEVEL=

# GOMA_DB_URL=postgresql://goma:goma@localhost:5432/goma?sslmode=disable
GOMA_ADMIN_EMAIL=admin@example.com
GOMA_ADMIN_PASSWORD=Admin@1234

# Frontend
GOMA_WEB_DIR=web/dist
GOMA_DOCKER_ENABLED=true
GOMA_DOCKER_HOST=
GOMA_DOCKER_ENABLE_SWARM=false

# Base URL of the application (used for OAuth callbacks, etc.)
GOMA_BASE_URL=http://localhost:9000

# Health checker — polls instance health endpoints in the background
GOMA_HEALTH_CHECK_ENABLED=true
GOMA_HEALTH_CHECK_INTERVAL=30s
GOMA_HEALTH_CHECK_TIMEOUT=5s

# Providers output directory — each instance gets its own subdirectory
GOMA_PROVIDERS_DIR=./data/providers
GOMA_REPO_SYNC_ENABLED=true
GOMA_REPO_SYNC_INTERVAL=2m

# TLS Certificate management
GOMA_ACME_STORAGE_FILE=/etc/letsencrypt/acme.json
GOMA_CERTS_DIR=/etc/goma/certs