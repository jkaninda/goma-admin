# =============================================================================
# Goma Admin - Docker Deployment Environment Variables
# =============================================================================
# Copy this file to .env and update the values for your environment:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# Option 1: Use individual database variables
GOMA_DB_HOST=goma-postgres
GOMA_DB_USER=goma
GOMA_DB_PASSWORD=goma
GOMA_DB_NAME=goma
GOMA_DB_PORT=5432
GOMA_DB_SSL_MODE=disable

# Option 2: Use a full database URL (overrides individual variables above)
# GOMA_DB_URL=postgresql://goma:goma@goma-postgres:5432/goma?sslmode=disable

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

GOMA_PORT=9000
GOMA_ENVIRONMENT=production
GOMA_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# IMPORTANT: Change this to a strong, random secret in production!
GOMA_JWT_SECRET=change-me-to-a-strong-random-secret
GOMA_JWT_ISSUER=goma-admin

# Encryption key for secrets at rest (metrics auth, etc.).
# If not set, falls back to GOMA_JWT_SECRET.
# GOMA_ENCRYPTION_KEY=change-me-to-a-strong-random-key

# CORS allowed origins (comma-separated). Use specific origins in production.
GOMA_CORS_ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# Admin Account
# -----------------------------------------------------------------------------

GOMA_ADMIN_EMAIL=admin@example.com
GOMA_ADMIN_PASSWORD=Admin@1234

# Set to false to disable OpenAPI docs in production
GOMA_ENABLE_DOCS=false

# Base URL of the application (used for OAuth callbacks, etc.)
GOMA_BASE_URL=http://localhost:9000

# -----------------------------------------------------------------------------
# Health Checker
# -----------------------------------------------------------------------------

# Polls instance health endpoints in the background
GOMA_HEALTH_CHECK_ENABLED=false
GOMA_HEALTH_CHECK_INTERVAL=30s
GOMA_HEALTH_CHECK_TIMEOUT=5s

# -----------------------------------------------------------------------------
# Docker Provider (optional)
# -----------------------------------------------------------------------------

# Enable to auto-discover routes from Docker container labels
GOMA_DOCKER_ENABLED=true
# GOMA_DOCKER_HOST=unix:///var/run/docker.sock
# GOMA_DOCKER_POLL_INTERVAL=10s
# GOMA_DOCKER_ENABLE_SWARM=false

# -----------------------------------------------------------------------------
# Providers Directory
# -----------------------------------------------------------------------------

# Directory where instance configuration files are written.
# Shared with Goma Gateway via a volume mount.
GOMA_PROVIDERS_DIR=/etc/goma/providers
